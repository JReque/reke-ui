{
  "name": "reke-ui",
  "version": "0.1.0",
  "description": "Component library built with Lit Element — dark terminal theme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/components/reke-button/reke-button.d.ts",
      "default": "./dist/components/reke-button/reke-button.js"
    },
    "./tokens/css": "./dist/tokens/reke-tokens.css"
  },
  "files": [
    "dist",
    "custom-elements.json"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly && mkdir -p dist/tokens && cp src/tokens/reke-tokens.css dist/tokens/",
    "build:storybook": "storybook build",
    "test": "vitest",
    "test:run": "vitest run",
    "analyze": "cem analyze --litelement",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "web-components",
    "lit",
    "design-system",
    "components"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@storybook/addon-a11y": "^10.2.11",
    "@storybook/web-components-vite": "^10.2.11",
    "@tailwindcss/vite": "^4.2.1",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "axe-core": "^4.11.1",
    "playwright": "^1.58.2",
    "storybook": "^10.2.11",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
